# Investor documents — public URLs (set in Vercel Project Env Vars).
NEXT_PUBLIC_INVESTOR_PITCH_DECK_URL=
NEXT_PUBLIC_INVESTOR_FINANCIAL_MODEL_URL=

# Origin of the client dashboard app (the "Client Login" nav CTA links to
# <this>/login). Defaults to the local dashboard dev server on :3001 when unset.
# In production set this to the deployed dashboard origin, e.g. https://app.aequoros.com
NEXT_PUBLIC_DASHBOARD_URL=

# Absolute URL of the dashboard's sign-in page (its own subdomain), e.g.
# https://app.aequoros.com/login. Falls back to <NEXT_PUBLIC_DASHBOARD_URL>/login
# when unset. In dev, http://localhost:3001/login.
NEXT_PUBLIC_LOGIN_URL=

# Resend API key — server-side only, NEVER commit. Put real value in .env.local
# Get yours at https://resend.com → API Keys
RESEND_API_KEY=

# Optional: sender address. Must be on a verified domain.
# Defaults to "AequorOS <onboarding@resend.dev>" (Resend's shared testing domain).
# Before launch, verify aequoros.com in Resend (Settings → Domains) and set this to
# RESEND_FROM_EMAIL="AequorOS <noreply@aequoros.com>"
RESEND_FROM_EMAIL=

# Optional: destination address for contact inquiries. Defaults to eric@aequoros.com.
RESEND_TO_EMAIL=
