# Resend API key — server-side only, never expose
# Get yours at https://resend.com → API Keys
RESEND_API_KEY=

# Optional: sender address. Must be on a verified domain.
# If unset, defaults to "AequorOS <onboarding@resend.dev>" (Resend's shared testing domain).
# Before launch, verify aequoros.com in Resend (Settings → Domains) and set this to e.g.
# RESEND_FROM_EMAIL="AequorOS <noreply@aequoros.com>"
RESEND_FROM_EMAIL=

# Optional: destination address for contact inquiries. Defaults to eric@aequoros.com.
RESEND_TO_EMAIL=
