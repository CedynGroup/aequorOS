# AequorOS dashboard — public (build-time) configuration.
#
# Copy this file to `.env.local` for local development, or set these variables
# in your deployment environment. NEXT_PUBLIC_* values are inlined at BUILD
# time, so changing the endpoint requires a rebuild — acceptable for the
# per-institution deployment model. (A runtime /config endpoint is a future
# option if a single build must serve multiple endpoints.)

# Full /api/v1 base of the risk service this console talks to.
# Production example: https://api.your-institution.aequoros.com/api/v1
NEXT_PUBLIC_RISK_API_BASE_URL=http://127.0.0.1:8003/api/v1

# Tenant identity sent as X-Org-Id / X-User-Id on every request. In production
# these are your provisioned organization UUID and service-account user UUID.
NEXT_PUBLIC_DEMO_ORG_ID=11111111-1111-4111-8111-111111111111
NEXT_PUBLIC_DEMO_USER_ID=aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa
