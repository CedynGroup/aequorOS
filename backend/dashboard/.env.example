# AequorOS dashboard — configuration.
#
# Copy this file to `.env.local` for local development, or set these variables
# in your deployment environment. NEXT_PUBLIC_* values are inlined at BUILD
# time; the AUTH*/SSO_* values are server-side secrets (never NEXT_PUBLIC_).

# Full /api/v1 base of the risk service this console talks to.
# Production example: https://api.your-institution.aequoros.com/api/v1
NEXT_PUBLIC_RISK_API_BASE_URL=http://127.0.0.1:8000/api/v1

# --- Authentication (NextAuth / Auth.js) -----------------------------------
# Secret that signs the NextAuth session (generate with `openssl rand -base64 32`).
AUTH_SECRET=change-me-openssl-rand-base64-32

# Own-OIDC SSO. The bank's IdP connection (issuer/client id/secret) is configured
# in the app itself (Settings -> Authentication) and stored in the backend; this
# key authenticates the dashboard server's internal fetch of that config. Must
# match the backend's SSO_INTERNAL_KEY. Generate: openssl rand -hex 32
SSO_INTERNAL_KEY=

# In the bank's IdP, register the redirect URI
#   {dashboard origin}/api/auth/callback/sso
# and the Allowed Logout URL to the dashboard origin.

# The tenant identity is no longer a client-side value — it comes from the signed
# access token the backend issues on login (NEXT_PUBLIC_DEMO_* removed).
