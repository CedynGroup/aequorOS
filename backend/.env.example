APP_ENV=local
APP_NAME=risk-service
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=INFO

# Primary database: the shared remote Postgres (managed, TimescaleDB-enabled).
# Real credentials live only in the untracked .env — never commit them.
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<postgres-host>:<port>/<database>
#
# Postgres-gated tests (migrations/RLS) opt in explicitly and run in a
# disposable per-run schema (risk_service_test_<hex>, dropped on teardown),
# so pointing them at the shared remote database is safe:
# TEST_DATABASE_URL=postgresql+psycopg://<user>:<password>@<postgres-host>:<port>/<database>
#
# Local fallback (docker compose up -d): postgresql+psycopg://postgres:postgres@localhost:15432/risk_service

# Object storage — one MinIO credential set serves the whole service (Data
# Engine canonical tiers + document uploads + presigned URLs + storage health).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aequoros
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
STORAGE_BACKEND=minio
STORAGE_ENV=mvp
# Mandatory for STORAGE_ENV=mvp: the date this self-hosted MinIO must be retired.
STORAGE_RETIRE_AFTER=2027-01-14
STORAGE_PRESIGN_EXPIRES_SECONDS=900
RISK_MAX_UPLOAD_BYTES=25000000
